{
  "version": "1.0",
  "rules": [
    {
      "id": "test-balanced-delegation",
      "name": "Test: Block Unlimited Delegations",
      "action": "block",
      "conditions": {
        "field": "security.delegation_is_unlimited",
        "operator": "equals",
        "value": true
      },
      "message": "Unlimited token delegation detected"
    },
    {
      "id": "test-balanced-blocked-programs",
      "name": "Test: Block Malicious Programs",
      "action": "block",
      "conditions": {
        "field": "security.blocked_program_detected",
        "operator": "equals",
        "value": true
      },
      "message": "Blocked program detected"
    },
    {
      "id": "test-balanced-critical-risk",
      "name": "Test: Block Critical Risk",
      "action": "block",
      "conditions": {
        "field": "security.risk_score",
        "operator": "greater_than_or_equal",
        "value": 90
      },
      "message": "Critical risk score"
    },
    {
      "id": "test-balanced-unverified-warning",
      "name": "Test: Warn on Unverified Programs",
      "action": "alert",
      "conditions": {
        "field": "ottersec.verification_ratio",
        "operator": "less_than",
        "value": 1.0
      },
      "message": "Some programs are unverified"
    },
    {
      "id": "test-balanced-multiple-delegations",
      "name": "Test: Warn on Multiple Delegations",
      "action": "alert",
      "conditions": {
        "field": "basic.delegation_count",
        "operator": "greater_than_or_equal",
        "value": 3
      },
      "message": "Multiple token approvals detected"
    }
  ]
}
