{
  "id": "custom-allowlist-only",
  "name": "Allow Only Specific Programs",
  "description": "Only allow transactions with specific programs (inverse of blocklist)",
  "enabled": false,
  "tags": ["custom", "restrictive", "allowlist"],
  "rule": {
    "conditions": {
      "any": [
        {
          "field": "basic:program_ids",
          "operator": "contains",
          "value": "TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA"
        },
        {
          "field": "basic:program_ids",
          "operator": "contains",
          "value": "11111111111111111111111111111111"
        }
      ]
    },
    "action": "pass",
    "message": "Transaction uses allowed program"
  }
}
