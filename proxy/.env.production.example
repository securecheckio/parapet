# Production Configuration Example for Parapet RPC Proxy
# Copy to .env and customize for your deployment

# ============================================================================
# UPSTREAM RPC CONFIGURATION
# ============================================================================

# Upstream Solana RPC endpoint (required)
UPSTREAM_RPC_URL=https://api.mainnet-beta.solana.com

# Rate Limiting
UPSTREAM_MAX_CONCURRENT=10          # Max concurrent requests to upstream
UPSTREAM_DELAY_MS=100               # Delay between requests (ms)

# Timeouts & Retries (NEW - Production Hardening)
UPSTREAM_TIMEOUT_SECS=30            # Request timeout in seconds
UPSTREAM_MAX_RETRIES=3              # Max retry attempts on transient failures
UPSTREAM_RETRY_BASE_DELAY_MS=100    # Base delay for exponential backoff

# Circuit Breaker (NEW - Prevents Cascading Failures)
UPSTREAM_CIRCUIT_BREAKER_THRESHOLD=5         # Failures before opening circuit
UPSTREAM_CIRCUIT_BREAKER_TIMEOUT_SECS=60     # Seconds before trying half-open

# ============================================================================
# REDIS CONFIGURATION (Optional but Recommended for Multi-Instance)
# ============================================================================

# Redis URL for shared caching across proxy instances
# Eliminates duplicate API calls, persists cache across restarts
REDIS_URL=redis://localhost:6379

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

PROXY_PORT=8899
BIND_ADDRESS=0.0.0.0

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Solana network
SOLANA_NETWORK=mainnet-beta

# Rules configuration
RULES_PATH=./rules/presets/comprehensive-protection.json
DEFAULT_BLOCKING_THRESHOLD=70

# Rule action override (optional: "pass", "alert", "block")
# RULE_ACTION_OVERRIDE=alert

# ============================================================================
# AUTHENTICATION (Choose one)
# ============================================================================

# Option 1: No authentication (default, for testing only)
AUTH_MODE=none

# Option 2: API key authentication
# AUTH_MODE=api_key
# API_KEYS=sk_prod_abc123,sk_prod_def456

# Option 3: Wallet allowlist
# AUTH_MODE=wallet_allowlist
# ALLOWED_WALLETS=wallet1,wallet2,wallet3

# ============================================================================
# USAGE TRACKING (Requires Redis)
# ============================================================================

ENABLE_USAGE_TRACKING=false
DEFAULT_REQUESTS_PER_MONTH=100000

# ============================================================================
# THIRD-PARTY ANALYZERS (Optional)
# ============================================================================

# Helius API (for identity, transfer, funding analyzers)
# HELIUS_API_KEY=your_helius_api_key_here
# HELIUS_RATE_LIMIT=20  # Requests per minute

# Jupiter API (for token metadata)
# JUPITER_API_KEY=your_jupiter_api_key_here

# ============================================================================
# WASM ANALYZERS (Optional)
# ============================================================================

WASM_ANALYZERS_PATH=./analyzers
# WASM_ANALYZER_CONFIG=./analyzer-config.json

# ============================================================================
# ESCALATIONS (Optional, requires Redis)
# ============================================================================

ENABLE_ESCALATIONS=false
# ESCALATION_APPROVER_WALLET=your_wallet_address_here

# ============================================================================
# RULE FEEDS (Optional - Auto-update rules from community sources)
# ============================================================================

RULES_FEED_ENABLED=false
RULES_FEED_POLL_INTERVAL=3600  # Seconds between polls
RULES_FEED_MIN_INTERVAL=300    # Min seconds between requests to same source

# Rule feed sources (comma-separated URLs)
# RULES_FEED_SOURCES=https://rules.securecheck.io/community.json,https://rules.example.com/custom.json

# ============================================================================
# PRODUCTION DEPLOYMENT RECOMMENDATIONS
# ============================================================================

# For high-traffic production deployments:
# 1. Enable Redis for shared caching (REDIS_URL)
# 2. Increase UPSTREAM_MAX_CONCURRENT based on your RPC provider limits
# 3. Adjust UPSTREAM_TIMEOUT_SECS based on your network conditions
# 4. Monitor circuit breaker state (logs will show OPEN/CLOSED transitions)
# 5. Use multiple proxy instances behind a load balancer
# 6. Enable usage tracking for monitoring (requires Redis)
# 7. Set up proper authentication (API keys or wallet allowlist)

# For multi-instance deployments:
# - All instances MUST share the same REDIS_URL
# - All instances should use the same RULES_PATH or RULES_FEED_ENABLED
# - Circuit breaker operates independently per instance (by design)

# Performance tuning:
# - UPSTREAM_MAX_CONCURRENT: Higher = more throughput, but respect RPC limits
# - UPSTREAM_DELAY_MS: Lower = faster, but may hit rate limits
# - UPSTREAM_TIMEOUT_SECS: Higher = more patience, but slower failure detection
# - UPSTREAM_CIRCUIT_BREAKER_THRESHOLD: Lower = faster failover, but more sensitive
