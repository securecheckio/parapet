# Parapet Complete Stack Environment Configuration

# ===========================================
# Solana Configuration
# ===========================================

# Upstream Solana RPC endpoint (proxy forwards requests here)
UPSTREAM_RPC_URL=https://api.mainnet-beta.solana.com

# Solana RPC for API (can be same or different)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ===========================================
# Security Configuration
# ===========================================

# Risk threshold for blocking transactions (0-100)
# Lower = stricter, Higher = more permissive
# Default: 70 (recommended for production)
DEFAULT_BLOCK_THRESHOLD=70

# Enable human-in-the-loop escalations for blocked transactions
# Set to "true" to allow manual approvals via dashboard
ENABLE_ESCALATIONS=true

# Wallet address authorized to approve escalations
# This is the wallet that can approve risky transactions
ESCALATION_APPROVER_WALLET=YOUR_WALLET_ADDRESS_HERE

# Authorized wallets for rule management (comma-separated)
# These wallets can create/modify security rules via API
AUTHORIZED_WALLETS=YOUR_WALLET_ADDRESS_HERE,ANOTHER_WALLET_ADDRESS

# ===========================================
# External API Keys (Optional but Recommended)
# ===========================================

# Helius API Key - Enables wallet identity verification
# Get one at: https://www.helius.dev/
HELIUS_API_KEY=

# Jupiter API Key - Enables token verification via Jupiter
# Get one at: https://station.jup.ag/api-keys
JUPITER_API_KEY=

# OtterSec API Key - Enables program verification
# Contact OtterSec for access
OTTERSEC_API_KEY=

# Note: Rugcheck API is FREE and requires no key

# ===========================================
# Rate Limiting Configuration
# ===========================================

# CRITICAL: Rugcheck public API limit is 15 requests/minute
# We use 10/60 for 33% safety buffer to avoid 429 errors
RUGCHECK_RATE_LIMIT=10/60

# Helius rate limits (adjust based on your plan)
HELIUS_RATE_LIMIT=20/60

# Jupiter rate limits
JUPITER_RATE_LIMIT=60/60

# OtterSec rate limits
OTTERSEC_RATE_LIMIT=30/60

# ===========================================
# Rules Configuration
# ===========================================

# Path to rules file (relative to /app/rules in container)
# Available presets:
#   - presets/default.json (balanced)
#   - presets/strict.json (maximum security)
#   - presets/permissive.json (minimal blocking)
RULES_PATH=/app/rules/presets/default.json

# ===========================================
# Logging Configuration
# ===========================================

# Rust logging level
# Options: error, warn, info, debug, trace
# Use "info" for production, "debug" for troubleshooting
RUST_LOG=info,sol_shield_proxy=debug,sol_shield_api=debug
