[
  {
    "version": "1.0",
    "id": "block-authority-change-fingerprint",
    "name": "Block Authority Change Fingerprints",
    "description": "Block transactions with known authority-change instruction fingerprints",
    "enabled": true,
    "tags": [
      "critical",
      "authority",
      "fingerprint"
    ],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "instruction_data:has_authority_change",
        "operator": "equals",
        "value": true
      },
      "message": "\ud83d\udea8 BLOCKED: Authority change instruction fingerprint detected"
    },
    "metadata": {
      "severity": "critical",
      "weight": 70,
      "false_positive_rate": "low",
      "note": "Requires fingerprint configuration file"
    }
  },
  {
    "version": "1.0",
    "id": "alert-suspicious-instruction-pattern",
    "name": "Alert on Suspicious Instruction Patterns",
    "description": "Warn when transaction contains known suspicious instruction patterns",
    "enabled": true,
    "tags": [
      "warning",
      "instruction",
      "pattern"
    ],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "instruction_data:has_match",
        "operator": "equals",
        "value": true
      },
      "message": "\u26a0\ufe0f WARNING: Known instruction pattern detected - review carefully"
    },
    "metadata": {
      "severity": "medium",
      "weight": 20
    }
  },
  {
    "version": "1.0",
    "id": "alert-transaction-log-errors",
    "name": "Alert on Transaction Log Errors",
    "description": "Warn when transaction logs contain error messages",
    "enabled": true,
    "tags": [
      "warning",
      "logs",
      "errors"
    ],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "logs:has_errors",
        "operator": "equals",
        "value": true
      },
      "message": "\u26a0\ufe0f Transaction contains error logs - may indicate failure or exploit"
    },
    "metadata": {
      "severity": "medium",
      "weight": 15,
      "note": "Requires confirmed transaction metadata with logs"
    }
  },
  {
    "version": "1.0",
    "id": "block-multiple-suspicious-patterns",
    "name": "Block Multiple Suspicious Log Patterns",
    "description": "Block when transaction logs show multiple suspicious patterns",
    "enabled": true,
    "tags": [
      "critical",
      "logs",
      "pattern"
    ],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {
            "field": "logs:suspicious_patterns",
            "operator": "not_equals",
            "value": []
          },
          {
            "field": "logs:log_count",
            "operator": "greater_than",
            "value": 5
          }
        ]
      },
      "message": "\ud83d\udea8 BLOCKED: Multiple suspicious patterns detected in transaction logs"
    },
    "metadata": {
      "severity": "critical",
      "weight": 60
    }
  }
]