[
  {
    "version": "1.0",
    "id": "max-trade-size",
    "name": "Maximum Trade Size",
    "description": "Prevents single transactions exceeding 100 SOL",
    "author": "securecheck",
    "enabled": true,
    "tags": ["spending", "limits"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "amount",
        "operator": "greater_than",
        "value": 100000000000
      },
      "message": "🚫 BLOCKED: Transaction amount exceeds 100 SOL limit"
    }
  },
  {
    "version": "1.0",
    "id": "complex-transaction-warning",
    "name": "Complex Transaction Warning",
    "description": "Warns on transactions with many instructions",
    "author": "securecheck",
    "enabled": true,
    "tags": ["complexity"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "instruction_count",
        "operator": "greater_than",
        "value": 10
      },
      "message": "⚠️  Complex transaction detected (>10 instructions). Review carefully."
    }
  }
]
