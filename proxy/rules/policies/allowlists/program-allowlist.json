[
  {
    "version": "1.0",
    "id": "allow-core-programs",
    "name": "Allow Core Solana Programs",
    "description": "Core programs are always safe (System, Token, Compute Budget)",
    "enabled": true,
    "tags": ["allowlist", "core"],
    "rule": {
      "action": "pass",
      "conditions": {
        "field": "complexity:non_core_program_count",
        "operator": "equals",
        "value": 0
      },
      "message": "✅ Transaction uses only core Solana programs"
    }
  },
