{
  "name": "Squads V4 Multisig Protection",
  "description": "Comprehensive protection rules for Squads Protocol v4 multisig operations",
  "version": "1.0.0",
  "rules": [
    {
      "id": "squads-v4-suspicious-threshold-change",
      "name": "Suspicious Squads Threshold Change",
      "description": "Detects threshold changes combined with other governance operations in a single transaction",
      "severity": "high",
      "enabled": true,
      "action": "alert",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.has_threshold_change",
            "operator": "equals",
            "value": true
          },
          {
            "field": "squads_v4.governance_change_count",
            "operator": "greater_than",
            "value": 1
          }
        ]
      },
      "metadata": {
        "category": "governance",
        "tags": [
          "squads",
          "multisig",
          "threshold",
          "governance"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    },
    {
      "id": "squads-v4-member-removal",
      "name": "Squads Member Removal Detected",
      "description": "Alerts when a member is removed from a Squads multisig",
      "severity": "medium",
      "enabled": true,
      "action": "alert",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.has_member_remove",
            "operator": "equals",
            "value": true
          }
        ]
      },
      "metadata": {
        "category": "governance",
        "tags": [
          "squads",
          "multisig",
          "member",
          "removal"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    },
    {
      "id": "squads-v4-rapid-governance-changes",
      "name": "Rapid Squads Governance Changes",
      "description": "Detects multiple governance changes in a single transaction (possible takeover attempt)",
      "severity": "critical",
      "enabled": true,
      "action": "block",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.governance_change_count",
            "operator": "greater_than_or_equal",
            "value": 3
          }
        ]
      },
      "metadata": {
        "category": "governance",
        "tags": [
          "squads",
          "multisig",
          "governance",
          "attack"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    },
    {
      "id": "squads-v4-execution-without-proposal",
      "name": "Squads Execution Without Proposal",
      "description": "Detects transaction execution without a visible proposal creation (possible bypass)",
      "severity": "high",
      "enabled": true,
      "action": "alert",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.security_concerns",
            "operator": "contains",
            "value": "execution_without_visible_proposal"
          }
        ]
      },
      "metadata": {
        "category": "governance",
        "tags": [
          "squads",
          "multisig",
          "proposal",
          "bypass"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    },
    {
      "id": "squads-v4-spending-limit-removal",
      "name": "Squads Spending Limit Removal",
      "description": "Alerts when spending limits are removed from a Squads multisig",
      "severity": "high",
      "enabled": true,
      "action": "alert",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.has_spending_limit_remove",
            "operator": "equals",
            "value": true
          }
        ]
      },
      "metadata": {
        "category": "governance",
        "tags": [
          "squads",
          "multisig",
          "spending-limit",
          "security"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    },
    {
      "id": "squads-v4-threshold-lowering",
      "name": "Squads Threshold Lowering",
      "description": "Detects when approval threshold is being changed (could be lowered to reduce security)",
      "severity": "high",
      "enabled": true,
      "action": "alert",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.has_threshold_change",
            "operator": "equals",
            "value": true
          }
        ]
      },
      "metadata": {
        "category": "governance",
        "tags": [
          "squads",
          "multisig",
          "threshold",
          "security"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    },
    {
      "id": "squads-v4-multiple-security-concerns",
      "name": "Multiple Squads Security Concerns",
      "description": "Detects transactions with multiple security concerns flagged",
      "severity": "critical",
      "enabled": true,
      "action": "block",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.concern_count",
            "operator": "greater_than_or_equal",
            "value": 2
          }
        ]
      },
      "metadata": {
        "category": "security",
        "tags": [
          "squads",
          "multisig",
          "security",
          "multiple-concerns"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    },
    {
      "id": "squads-v4-governance-with-execution",
      "name": "Squads Governance Change with Immediate Execution",
      "description": "Detects governance changes combined with transaction execution in same transaction",
      "severity": "critical",
      "enabled": true,
      "action": "block",
      "conditions": {
        "all": [
          {
            "field": "squads_v4.has_governance_change",
            "operator": "equals",
            "value": true
          },
          {
            "field": "squads_v4.execution_count",
            "operator": "greater_than",
            "value": 0
          }
        ]
      },
      "metadata": {
        "category": "governance",
        "tags": [
          "squads",
          "multisig",
          "governance",
          "execution",
          "attack"
        ],
        "references": [
          "https://docs.squads.so/"
        ]
      }
    }
  ],
  "metadata": {
    "author": "Parapet Security Team",
    "created": "2026-04-07",
    "updated": "2026-04-07",
    "tags": [
      "squads",
      "multisig",
      "governance",
      "v4"
    ],
    "category": "protocol-specific"
  }
}