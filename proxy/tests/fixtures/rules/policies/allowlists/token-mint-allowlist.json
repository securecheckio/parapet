[
  {
    "version": "1.0",
    "id": "allow-usdc-only",
    "name": "Allow USDC Transfers Only",
    "description": "Only allow transfers of USDC (mainnet mint)",
    "enabled": false,
    "tags": ["allowlist", "mint", "strict"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "token_instructions:has_transfer", "operator": "equals", "value": true},
          {
            "not": {
              "field": "token_instructions:mints_involved",
              "operator": "contains",
              "value": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
            }
          }
        ]
      },
      "message": "🚨 BLOCKED: Only USDC transfers allowed"
    },
    "metadata": {
      "mint": "USDC",
      "mint_address": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
    }
  },
  {
    "version": "1.0",
    "id": "allow-stablecoins-only",
    "name": "Allow Stablecoins Only",
    "description": "Restrict transfers to known stablecoins (USDC, USDT, UXD)",
    "enabled": false,
    "tags": ["allowlist", "mint", "stablecoin"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "token_instructions:has_transfer", "operator": "equals", "value": true},
          {
            "not": {
              "field": "token_instructions:mints_involved",
              "operator": "in",
              "value": [
                "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",
                "Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB",
                "7kbnvuGBxxj8AG9qp8Scn56muWGaRaFqxg1FsRp3PaFT"
              ]
            }
          }
        ]
      },
      "message": "🚨 BLOCKED: Only stablecoin transfers allowed (USDC, USDT, UXD)"
    },
    "metadata": {
      "mints": {
        "USDC": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v",
        "USDT": "Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB",
        "UXD": "7kbnvuGBxxj8AG9qp8Scn56muWGaRaFqxg1FsRp3PaFT"
      }
    }
  },
  {
    "version": "1.0",
    "id": "block-suspicious-mint",
    "name": "Block Known Scam Token Mints",
    "description": "Block transfers of known scam tokens",
    "enabled": true,
    "tags": ["blocklist", "mint", "scam"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "token_instructions:mints_involved",
        "operator": "in",
        "value": [
          "ScamMint1111111111111111111111111111111",
          "ScamMint2222222222222222222222222222222"
        ]
      },
      "message": "🚨 BLOCKED: Known scam token detected"
    },
    "metadata": {
      "note": "Add known scam mint addresses here"
    }
  },
  {
    "version": "1.0",
    "id": "alert-multiple-mints",
    "name": "Alert on Multiple Token Types",
    "description": "Warn when transaction involves 3+ different tokens",
    "enabled": true,
    "tags": ["alert", "mint", "complexity"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "token_instructions:mints_involved",
        "operator": "array_length_greater_than",
        "value": 2
      },
      "message": "⚠️ WARNING: Transaction involves multiple token types - verify each carefully"
    }
  },
  {
    "version": "1.0",
    "id": "prefer-transfer-checked",
    "name": "Prefer TransferChecked Instructions",
    "description": "Alert if using old Transfer instead of TransferChecked",
    "enabled": false,
    "tags": ["alert", "best-practice"],
    "rule": {
      "action": "alert",
      "conditions": {
        "all": [
          {"field": "token_instructions:has_transfer", "operator": "equals", "value": true},
          {"field": "token_instructions:uses_transfer_checked", "operator": "equals", "value": false}
        ]
      },
      "message": "⚠️ WARNING: Using old Transfer instruction - TransferChecked is safer"
    }
  }
]
