  {
    "version": "1.0",
    "id": "block-non-allowlisted",
    "name": "Block Non-Allowlisted Programs",
    "description": "Block any programs not on the allowlist",
    "enabled": false,
    "tags": ["allowlist", "strict"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "complexity:non_core_program_count",
        "operator": "greater_than",
        "value": 0
      },
      "message": "🚨 BLOCKED: Transaction uses non-allowlisted programs"
    },
    "metadata": {
      "note": "Enable this for strict allowlist mode. Combine with specific DEX/protocol allow rules."
    }
  },
  {
    "version": "1.0",
    "id": "alert-non-core-programs",
    "name": "Alert on Non-Core Programs",
    "description": "Warn when transaction uses programs beyond core Solana",
    "enabled": true,
    "tags": ["alert", "programs"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "complexity:non_core_program_count",
        "operator": "greater_than",
        "value": 0
      },
      "message": "⚠️ Transaction uses non-core programs - verify you trust them"
