[
  {
    "version": "1.0",
    "id": "alert-unlimited-delegation",
    "name": "Unlimited Delegation Alert",
    "description": "Detects unlimited token approvals (u64::MAX) which can indicate drain attacks",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "critical", "delegation"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "token_instructions:unlimited_approve_count",
        "operator": "greater_than",
        "value": 0
      },
      "message": "⚠️ Unlimited token delegation detected (u64::MAX)"
    },
    "metadata": {
      "severity": "critical",
      "false_positive_rate": 0.001,
      "weight": 40
    }
  },
  {
    "version": "1.0",
    "id": "block-malicious-programs",
    "name": "Known Malicious Program",
    "description": "Blocks transactions involving known malicious programs (signature-based)",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "critical", "blocklist", "signature"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "security:blocked_program_detected",
        "operator": "equals",
        "value": true
      },
      "message": "🚨 Known malicious program detected"
    },
    "metadata": {
      "severity": "critical",
      "false_positive_rate": 0.0,
      "weight": 100
    }
  },
  {
    "version": "1.0",
    "id": "alert-large-sol-transfer",
    "name": "Large SOL Transfer Alert",
    "description": "Alerts when transaction transfers >5 SOL",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "risk"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "system:max_sol_transfer",
        "operator": "greater_than",
        "value": 5000000000
      },
      "message": "⚠️ Large SOL transfer detected (>5 SOL)"
    },
    "metadata": {
      "severity": "high",
      "weight": 50
    }
  },
  {
    "version": "1.0",
    "id": "alert-multiple-approvals",
    "name": "Multiple Delegations Alert",
    "description": "Warns when transaction has 3+ token approvals",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "delegation"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "token_instructions:approve_count",
        "operator": "greater_than_or_equal",
        "value": 3
      },
      "message": "⚠️ Multiple token approvals detected (3+)"
    },
    "metadata": {
      "severity": "high",
      "weight": 30
    }
  },
  {
    "version": "1.0",
    "id": "alert-unverified-program-with-approvals",
    "name": "Unverified Program with Approvals",
    "description": "Alerts when unverified programs request token approvals (requires OtterSec)",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "verification", "ottersec"],
    "rule": {
      "action": "alert",
      "conditions": {
        "all": [
          {"field": "token_instructions:approve_count", "operator": "greater_than", "value": 0},
          {"field": "ottersec:all_programs_verified", "operator": "equals", "value": false}
        ]
      },
      "message": "⚠️ Token approval requested by unverified program"
    },
    "metadata": {
      "severity": "high",
      "weight": 40,
      "comment": "Requires OtterSec analyzer to be enabled"
    }
  },
  {
    "version": "1.0",
    "id": "block-scammer-interaction",
    "name": "Known Scammer Interaction",
    "description": "Blocks transactions involving addresses tagged as scammers (requires Helius)",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "scam", "helius"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "helius_identity:other_classifications",
        "operator": "contains",
        "value": "scammer"
      },
      "message": "🚨 Transaction involves known scammer address"
    },
    "metadata": {
      "severity": "critical",
      "weight": 100,
      "comment": "Requires Helius analyzer to be enabled"
    }
  },
  {
    "version": "1.0",
    "id": "alert-suspicious-interaction",
    "name": "Suspicious Address Interaction",
    "description": "Warns about interactions with suspicious addresses (requires Helius)",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "suspicious", "helius"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "helius_identity:other_classifications",
        "operator": "contains",
        "value": "suspicious"
      },
      "message": "⚠️ Transaction involves suspicious address"
    },
    "metadata": {
      "severity": "high",
      "weight": 40,
      "comment": "Requires Helius analyzer to be enabled"
    }
  }
]
