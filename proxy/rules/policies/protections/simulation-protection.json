[
  {
    "version": "1.0",
    "id": "block-sol-balance-drain",
    "name": "Block Large SOL Balance Drain",
    "description": "Block transactions that drain significant SOL from wallet (simulation-detected)",
    "enabled": true,
    "tags": ["critical", "simulation", "balance", "drain"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "simulation_balance:has_sol_drain", "operator": "equals", "value": true},
          {"field": "simulation_balance:sol_decrease", "operator": "greater_than", "value": 5000000000}
        ]
      },
      "message": "🚨 BLOCKED: Large SOL drain detected in simulation (>5 SOL)"
    },
    "metadata": {
      "severity": "critical",
      "weight": 80,
      "false_positive_rate": "low",
      "note": "Requires simulation - not available for pre-send analysis"
    }
  },
  {
    "version": "1.0",
    "id": "alert-sol-balance-decrease",
    "name": "Alert on SOL Balance Decrease",
    "description": "Warn when simulation shows SOL balance decrease",
    "enabled": true,
    "tags": ["warning", "simulation", "balance"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "simulation_balance:sol_decrease",
        "operator": "greater_than",
        "value": 1000000000
      },
      "message": "⚠️ WARNING: Transaction will decrease SOL balance (>1 SOL)"
    },
    "metadata": {
      "severity": "medium",
      "weight": 20
    }
  },
  {
    "version": "1.0",
    "id": "block-token-balance-drain",
    "name": "Block Token Balance Drain",
    "description": "Block transactions that drain token balances (simulation-detected)",
    "enabled": true,
    "tags": ["critical", "simulation", "token", "drain"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "simulation_token:has_token_drain", "operator": "equals", "value": true},
          {"field": "simulation_token:largest_change_pct", "operator": "greater_than", "value": 50}
        ]
      },
      "message": "🚨 BLOCKED: Large token balance drain detected (>50%)"
    },
    "metadata": {
      "severity": "critical",
      "weight": 75
    }
  },
  {
    "version": "1.0",
    "id": "alert-token-balance-change",
    "name": "Alert on Token Balance Changes",
    "description": "Warn when simulation shows significant token balance changes",
    "enabled": true,
    "tags": ["warning", "simulation", "token"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "simulation_token:token_count",
        "operator": "greater_than",
        "value": 0
      },
      "message": "⚠️ Token balance changes detected in simulation"
    },
    "metadata": {
      "severity": "medium",
      "weight": 15
    }
  },
  {
    "version": "1.0",
    "id": "block-high-compute-usage",
    "name": "Block Excessive Compute Usage",
    "description": "Block transactions with extremely high compute unit consumption",
    "enabled": true,
    "tags": ["critical", "simulation", "compute"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "simulation_compute:units_consumed",
        "operator": "greater_than",
        "value": 1300000
      },
      "message": "🚨 BLOCKED: Excessive compute usage (>1.3M units)"
    },
    "metadata": {
      "severity": "high",
      "weight": 50,
      "note": "Solana compute limit is 1.4M units per transaction"
    }
  },
  {
    "version": "1.0",
    "id": "alert-high-compute-usage",
    "name": "Alert on High Compute Usage",
    "description": "Warn on transactions using >80% of compute limit",
    "enabled": true,
    "tags": ["warning", "simulation", "compute"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "simulation_compute:units_consumed",
        "operator": "greater_than",
        "value": 1100000
      },
      "message": "⚠️ High compute usage detected (>1.1M units)"
    },
    "metadata": {
      "severity": "medium",
      "weight": 20
    }
  },
  {
    "version": "1.0",
    "id": "alert-intentional-failure",
    "name": "Alert on Intentional Simulation Failure",
    "description": "Warn when simulation failure appears intentional (exploit pattern)",
    "enabled": true,
    "tags": ["critical", "simulation", "failure"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "simulation_failure:is_intentional",
        "operator": "equals",
        "value": true
      },
      "message": "⚠️ WARNING: Intentional simulation failure detected - possible exploit"
    },
    "metadata": {
      "severity": "critical",
      "weight": 45
    }
  },
  {
    "version": "1.0",
    "id": "block-simulation-failure-with-drain",
    "name": "Block Simulation Failure with Balance Drain",
    "description": "Block if simulation fails but shows balance decrease (suspicious pattern)",
    "enabled": true,
    "tags": ["critical", "simulation", "failure", "drain"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "simulation_failure:failed", "operator": "equals", "value": true},
          {"field": "simulation_balance:sol_decrease", "operator": "greater_than", "value": 100000000}
        ]
      },
      "message": "🚨 BLOCKED: Simulation failed but shows balance drain - highly suspicious"
    },
    "metadata": {
      "severity": "critical",
      "weight": 85
    }
  }
]
