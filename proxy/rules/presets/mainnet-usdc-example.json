[
  {
    "version": "1.0",
    "id": "mainnet-usdc-large-transfer",
    "name": "Mainnet USDC Large Transfer",
    "description": "Alerts on USDC transfers over $1000 on mainnet",
    "author": "securecheck",
    "enabled": true,
    "tags": ["mainnet", "usdc", "high-value"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "token_instructions:has_transfer",
        "operator": "equals",
        "value": true
      },
      "message": "⚠️ MAINNET ALERT: Large USDC transfer detected - verify recipient"
    },
    "metadata": {
      "severity": "high",
      "weight": 50,
      "networks": "mainnet-beta",
      "token_mint": "EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"
    }
  },
