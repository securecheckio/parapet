[
  {
    "version": "1.0",
    "id": "block-unlimited-delegation",
    "name": "Block Unlimited Token Delegations",
    "description": "Prevents unlimited token approvals (u64::MAX) - the most common drain attack",
    "enabled": true,
    "tags": ["critical", "delegation"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "token_instructions:unlimited_approve_count",
        "operator": "greater_than",
        "value": 0
      },
      "message": "🚨 BLOCKED: Unlimited token delegation detected (u64::MAX)"
    }
  },
  {
    "version": "1.0",
    "id": "block-freeze-with-approval",
    "name": "Block Freeze + Approval Combo",
    "description": "Dangerous combination of freeze authority with token approval",
    "enabled": true,
    "tags": ["critical", "combo-attack"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "token_instructions:has_freeze", "operator": "equals", "value": true},
          {"field": "token_instructions:has_approve", "operator": "equals", "value": true}
        ]
      },
      "message": "🚨 BLOCKED: Freeze + Approval combination detected (freeze attack)"
    }
  },
  {
    "version": "1.0",
    "id": "block-burn-with-approval",
    "name": "Block Burn + Approval Combo",
    "description": "Prevents burn operations combined with approvals",
    "enabled": true,
    "tags": ["critical", "combo-attack"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "token_instructions:has_burn", "operator": "equals", "value": true},
          {"field": "token_instructions:has_approve", "operator": "equals", "value": true}
        ]
      },
      "message": "🚨 BLOCKED: Burn + Approval combination detected"
    }
  },
  {
    "version": "1.0",
    "id": "alert-any-burn",
    "name": "Alert on Token Burns",
    "description": "Warns when transaction will destroy tokens",
    "enabled": true,
    "tags": ["high", "burn"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "token_instructions:has_burn",
        "operator": "equals",
        "value": true
      },
      "message": "⚠️ WARNING: Token burn detected - your tokens will be destroyed!"
    }
  },
  {
    "version": "1.0",
    "id": "alert-freeze-operation",
    "name": "Alert on Freeze Operations",
    "description": "Warns when freeze/thaw operations are detected",
    "enabled": true,
    "tags": ["high", "freeze"],
    "rule": {
      "action": "alert",
      "conditions": {
        "any": [
          {"field": "token_instructions:has_freeze", "operator": "equals", "value": true},
          {"field": "token_instructions:has_thaw", "operator": "equals", "value": true}
        ]
      },
      "message": "⚠️ WARNING: Account freeze/thaw operation detected"
    }
  },
  {
    "version": "1.0",
    "id": "allow-revoke",
    "name": "Pass Revoke Operations",
    "description": "Explicitly allows revoke-only transactions (security improvement)",
    "enabled": true,
    "tags": ["safe", "revoke"],
    "rule": {
      "action": "pass",
      "conditions": {
        "all": [
          {"field": "token_instructions:has_revoke", "operator": "equals", "value": true},
          {"field": "token_instructions:approve_count", "operator": "equals", "value": 0}
        ]
      },
      "message": "✅ SAFE: Revoking token delegation (security improvement)"
    }
  },
  {
    "version": "1.0",
    "id": "block-net-delegation-increase",
    "name": "Block Net Delegation Increase",
    "description": "Blocks if approvals > revokes",
    "enabled": true,
    "tags": ["critical", "delegation"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "token_instructions:net_delegation_change",
        "operator": "greater_than",
        "value": 0
      },
      "message": "🚨 BLOCKED: Net increase in token delegations"
    }
  },
  {
    "version": "1.0",
    "id": "alert-mint-operation",
    "name": "Alert on Token Minting",
    "description": "Warns when new tokens are being minted",
    "enabled": true,
    "tags": ["medium", "supply"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "token_instructions:has_mint",
        "operator": "equals",
        "value": true
      },
      "message": "⚠️ WARNING: Token minting detected - supply will increase"
    }
  },
  {
    "version": "1.0",
    "id": "block-large-sol-transfer",
    "name": "Block Large SOL Transfers",
    "description": "Blocks transfers over 5 SOL to prevent drain attacks",
    "enabled": true,
    "tags": ["high", "sol-transfer"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "system:max_sol_transfer",
        "operator": "greater_than",
        "value": 5000000000
      },
      "message": "🚨 BLOCKED: Large SOL transfer detected (> 5 SOL)"
    }
  },
  {
    "version": "1.0",
    "id": "alert-sol-transfer",
    "name": "Alert on SOL Transfers",
    "description": "Warns on any SOL transfer over 0.1 SOL",
    "enabled": true,
    "tags": ["medium", "sol-transfer"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "system:max_sol_transfer",
        "operator": "greater_than",
        "value": 100000000
      },
      "message": "⚠️ WARNING: SOL transfer detected"
    }
  },
  {
    "version": "1.0",
    "id": "block-account-spam",
    "name": "Block Account Creation Spam",
    "description": "Prevents creation of excessive accounts (rent drain)",
    "enabled": true,
    "tags": ["high", "spam"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "system:account_creation_count",
        "operator": "greater_than",
        "value": 20
      },
      "message": "🚨 BLOCKED: Excessive account creation (> 20 accounts) - spam attack"
    }
  },
  {
    "version": "1.0",
    "id": "alert-account-creation",
    "name": "Alert on Account Creation",
    "description": "Warns when 3+ accounts are being created",
    "enabled": true,
    "tags": ["medium", "accounts"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "system:account_creation_count",
        "operator": "greater_than_or_equal",
        "value": 3
      },
      "message": "⚠️ WARNING: Creating multiple accounts - will cost rent"
    }
  },
  {
    "version": "1.0",
    "id": "block-complex-non-core",
    "name": "Block Complex Non-Core Programs",
    "description": "Blocks complex transactions with multiple non-core programs",
    "enabled": true,
    "tags": ["high", "complexity"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {"field": "complexity:non_core_program_count", "operator": "greater_than", "value": 2},
          {"field": "complexity:complexity_score", "operator": "greater_than", "value": 70}
        ]
      },
      "message": "🚨 BLOCKED: Complex transaction with multiple non-core programs"
    }
  },
  {
    "version": "1.0",
    "id": "alert-high-complexity",
    "name": "Alert on High Complexity",
    "description": "Warns on transactions with high complexity score",
    "enabled": true,
    "tags": ["medium", "complexity"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "complexity:complexity_score",
        "operator": "greater_than",
        "value": 60
      },
      "message": "⚠️ WARNING: Complex transaction detected - review carefully"
    }
  },
  {
    "version": "1.0",
    "id": "block-writable-non-signer",
    "name": "Block Writable Non-Signers",
    "description": "Prevents account confusion attacks (Wormhole-style missing signer checks)",
    "enabled": true,
    "tags": ["critical", "account-confusion", "wormhole"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "complexity:writable_non_signer_count",
        "operator": "greater_than",
        "value": 5
      },
      "message": "🚨 BLOCKED: Many writable accounts without signatures - potential Wormhole-style attack"
    }
  },
  {
    "version": "1.0",
    "id": "block-dangerous-combo",
    "name": "Block Dangerous Operation Combinations",
    "description": "Blocks suspicious instruction combinations",
    "enabled": true,
    "tags": ["critical", "combo-attack"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "token_instructions:dangerous_operation_combo",
        "operator": "equals",
        "value": true
      },
      "message": "🚨 BLOCKED: Dangerous instruction combination detected"
    }
  },
  {
    "version": "1.0",
    "id": "block-blocked-programs",
    "name": "Block Known Malicious Programs",
    "description": "Blocks transactions involving blocklisted programs",
    "enabled": true,
    "tags": ["critical", "blocklist"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "core_security:blocked_program_detected",
        "operator": "equals",
        "value": true
      },
      "message": "🚨 BLOCKED: Transaction involves known malicious program"
    }
  }
]
