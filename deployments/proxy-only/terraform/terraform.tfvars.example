# ====================================
# Parapet Terraform Configuration
# ====================================
# Copy this file to terraform.tfvars and fill in your values

# ----------------
# General Settings
# ----------------
deployment_name = "production"  # Name for your deployment (production, staging, dev)

# -----------------------
# Deployment Mode
# -----------------------
# Choose deployment strategy:
# - "docker": Easy deployment, portable, ~2-5% overhead (recommended for open-source users)
# - "native": Maximum performance, ~2-5% faster, best for high-throughput production (>5000 req/s)
deployment_mode = "docker"

# -----------------------
# RPC Configuration
# -----------------------
# Your upstream Solana RPC URL (Helius, QuickNode, etc.)
upstream_rpc_url = "https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE"

# Port for Parapet proxy (default: 8899)
proxy_port = 8899

# -----------------------
# Security & Rate Limiting
# -----------------------
# Enable rate limiting per wallet address
enable_rate_limiting = false

# Default monthly request limit per wallet (if rate limiting enabled)
default_requests_per_month = 10000

# Comma-separated allowlisted wallets (empty = all allowed)
# Example: "wallet1,wallet2,wallet3"
allowlisted_wallets = ""

# -----------------------
# SSH Access
# -----------------------
# Path to your SSH public key
ssh_public_key_path = "~/.ssh/id_rsa.pub"

# IP addresses allowed to SSH (CIDR notation)
# IMPORTANT: Change this to your IP for production security!
# Example: ssh_allowed_ips = ["1.2.3.4/32", "5.6.7.0/24"]
ssh_allowed_ips = ["0.0.0.0/0"]

# IP addresses allowed to access HTTPS/RPC (CIDR notation)  
# IMPORTANT: Change this to your allowed IPs for production!
# Example: https_allowed_ips = ["1.2.3.4/32", "5.6.7.0/24"]
https_allowed_ips = ["0.0.0.0/0", "::/0"]

# -----------------------
# HTTPS Configuration (Optional)
# -----------------------
# Enable automatic HTTPS with Let's Encrypt (requires domain name)
enable_https = false

# Your domain name (e.g., rpc.yourdomain.com)
# domain_name = "rpc.yourdomain.com"

# Email for Let's Encrypt notifications (certificate expiry, etc.)
# email = "you@email.com"

# -----------------------
# DNS Management (Optional but Recommended)
# -----------------------
# Automatically manage DNS in DigitalOcean (requires domain hosted in DO)
# manage_dns = true

# Base domain/zone in DigitalOcean (e.g., "yourdomain.com")
# Required if manage_dns = true
# dns_zone = "yourdomain.com"

# IMPORTANT: 
# - If manage_dns = true: Terraform automatically updates DNS → No manual steps!
# - If manage_dns = false: You must manually update DNS AFTER deployment
#   (Get IP from: terraform output droplet_ip)

# -----------------------
# Security Rules Configuration
# -----------------------
# How to load security rules:
# - "feed": Auto-updating rules from HTTP (recommended, zero-downtime updates)
# - "local": Static rules file on server (manual updates via SSH OR deploy from local file)
# - "embedded": Use rules packaged in Docker image (no external dependencies)
rules_source = "feed"

# Rules feed URL (only used if rules_source = "feed")
# Recommended: Community rules that work without API keys
rules_feed_url = "https://parapet-rules.securecheck.io/community/core-protection.json"

# Enable automatic rule updates from feeds
rules_feed_enabled = true

# Check for rule updates every N seconds (default: 3600 = 1 hour)
# Recommendations: 3600 (balanced), 600 (high-security), 7200 (cost-conscious)
rules_feed_poll_interval = 3600

# Deploy custom rules from local file (only used if rules_source = "local")
# Example: local_rules_file = "../rules/my-custom-rules.json"
# If empty, uses default built-in rules
# local_rules_file = ""

# -----------------------
# Cloud Provider Specific
# -----------------------

# === DigitalOcean ===
# Uncomment for DigitalOcean deployment
# do_token = "YOUR_DIGITALOCEAN_TOKEN"
# region = "nyc3"
# droplet_size = "s-2vcpu-2gb"
# redis_enabled = false
# use_reserved_ip = false

# === AWS ===
# Uncomment for AWS deployment
# region = "us-east-1"
# instance_type = "t3.small"
# root_volume_size = 20
# redis_enabled = false
# use_elastic_ip = false

# -----------------------
# Optional: Redis
# -----------------------
# Enable managed Redis for caching and rate limiting
# redis_enabled = true

# DigitalOcean Redis size
# redis_size = "db-s-1vcpu-1gb"

# AWS Redis node type
# redis_node_type = "cache.t3.micro"

# -----------------------
# Optional: Tags
# -----------------------
# Additional tags for resources
tags = ["parapet", "production"]  # For DigitalOcean
# tags = {                            # For AWS
#   Environment = "production"
#   Project     = "parapet"
# }
