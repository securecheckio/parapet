# Devnet Testing Configuration
# Copy this to .env to test with Solana devnet

# Helius Devnet RPC (better performance than public RPC)
UPSTREAM_RPC_URL=https://devnet.helius-rpc.com/?api-key=a1dcb99c-304a-458f-b4d6-a9fcdb8eb7e3

# Alternative: Free public devnet (slower, rate limited)
# UPSTREAM_RPC_URL=https://api.devnet.solana.com

# Server Configuration
PROXY_PORT=8899
RUST_LOG=info,parapet_rpc_proxy=debug,parapet_core=debug

# Redis (optional for devnet testing)
# REDIS_URL=redis://localhost:6379

# Rate Limiting (disabled for devnet testing)
ENABLE_RATE_LIMITING=false

# Test Rules (for devnet testing)
RULES_PATH=./tests/fixtures/rules/examples/test-complete.json
# RULES_PATH=./tests/fixtures/rules/examples/test-permissive.json
# RULES_PATH=./tests/fixtures/rules/examples/test-balanced.json
# RULES_PATH=./tests/fixtures/rules/examples/test-strict.json

# Production Rules (examples - don't use for testing)
# RULES_PATH=./rules/presets/bot-essentials.json
# RULES_PATH=./tests/fixtures/rules/presets/anti-scam.json
# RULES_PATH=./tests/fixtures/rules/policies/protections/ottersec-verified-only.json
# RULES_PATH=./tests/fixtures/rules/policies/protections/spending-limits.json

# Helius API Key (enables HeliusIdentityAnalyzer for wallet reputation)
HELIUS_API_KEY=a1dcb99c-304a-458f-b4d6-a9fcdb8eb7e3
