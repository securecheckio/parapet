  {
    "version": "1.0",
    "id": "allow-jupiter-delegate",
    "name": "Allow Delegation to Jupiter",
    "description": "Allow token approvals specifically to Jupiter aggregator",
    "enabled": true,
    "tags": ["allowlist", "delegation", "jupiter"],
    "rule": {
      "action": "pass",
      "conditions": {
        "all": [
          {"field": "token_instructions:has_approve", "operator": "equals", "value": true},
          {"field": "token_instructions:delegate_addresses", "operator": "contains", "value": "JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4"}
        ]
      },
      "message": "✅ ALLOWED: Delegation to Jupiter v6"
    },
    "metadata": {
      "program": "Jupiter v6",
      "program_id": "JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4"
    }
  },
