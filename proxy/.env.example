# Parapet RPC Proxy Configuration

# Required: Upstream Solana RPC endpoint
UPSTREAM_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Redis for caching and rate limiting
# If not set, uses in-memory cache
REDIS_URL=redis://localhost:6379

# Optional: Proxy port (default: 8899)
PROXY_PORT=8899

# Upstream Rate Limiting (prevents hitting provider's rate limits)
# Max concurrent requests to upstream RPC (default: 10)
UPSTREAM_MAX_CONCURRENT=10
# Minimum delay between requests in milliseconds (default: 100)
UPSTREAM_DELAY_MS=100

# Network Configuration (for network-aware rule filtering)
# Determines which rules are loaded based on "networks" field in rule metadata
# Options: mainnet-beta, devnet, testnet
# Default: mainnet-beta (production safety)
# Rules without "networks" metadata default to mainnet-only for safety
SOLANA_NETWORK=mainnet-beta

# Default Blocking Threshold (0-100, default: 70)
# Determines when accumulated risk weight triggers a block
# - 50: Strict (blocks at lower risk - more false positives)
# - 70: Balanced (recommended for most use cases)
# - 85: Relaxed (only blocks high-risk transactions)
# In SaaS mode, users can override this per-account in the dashboard
DEFAULT_BLOCKING_THRESHOLD=70

# Optional: Bind address (default: 0.0.0.0)
# Examples:
#   0.0.0.0   - Listen on all interfaces (public)
#   127.0.0.1 - Listen on localhost only (private)
#   10.0.0.5  - Listen on specific IP
BIND_ADDRESS=0.0.0.0

# Optional: Authentication mode (none, api_key, wallet_allowlist)
AUTH_MODE=none

# API Key Authentication (when AUTH_MODE=api_key)
# Format: key:userid[:wallet1,wallet2,...]
# - Simple (read-only): "key1:user1,key2:user2"
# - With wallets (for transactions): "key1:user1:wallet1,wallet2|key2:user2:wallet3"
# - Use | separator when including wallets (since , is used within wallet lists)
# API_KEYS=sk_test:user1:7xKXtg...,5Q544f...|sk_prod:user2:AnotherWallet...

# ============================================================================
# Output Formatters (Forensic Audit Trail)
# ============================================================================

# Enable output formatters (comma-separated)
# Available: json-ls, iso20022, xbrl-json, 1099-da
# OUTPUT_FORMATS=json-ls,xbrl-json

# JSON-LS (Splunk/Security Monitoring)
# JSONLS_ENABLED=true
# JSONLS_SINK=http
# JSONLS_URL=https://splunk.example.com:8088/services/collector
# JSONLS_TOKEN=your-hec-token

# ISO 20022 (SWIFT/Banking)
# ISO20022_ENABLED=true
# ISO20022_SINK=file
# ISO20022_PATH=./output/iso20022

# xBRL-JSON (SEC/MiCA Reporting)
# XBRL_ENABLED=true
# XBRL_SINK=file
# XBRL_PATH=./output/xbrl

# Form 1099-DA (IRS Digital Asset Reporting)
# FORM1099DA_ENABLED=true
# FORM1099DA_SINK=file
# FORM1099DA_PATH=./output/tax

# Optional: Usage tracking (default: false)
ENABLE_USAGE_TRACKING=false
DEFAULT_REQUESTS_PER_MONTH=10000

# Optional: Wallet allowlist (comma-separated)
# ALLOWED_WALLETS=7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU,5Q544fKrFoe6tsEbD7S8EmxGTJYAKtTVhAW5Q5pge4j1

# Optional: Blocked programs (comma-separated)
# BLOCKED_PROGRAMS=ProgramID1,ProgramID2

# Optional: Rules file path (default: ./rules/bot-essentials.json)
# RULES_PATH=./rules/presets/bot-essentials.json

# Optional: Rule action override
# Override all rule actions (use with caution!)
# RULE_ACTION_OVERRIDE=all:alert  # Override everything to alert
# RULE_ACTION_OVERRIDE=block:alert,alert:pass  # Override specific actions

# Optional: WASM analyzers directory (default: ./analyzers)
# Set to "none" or "disabled" to disable WASM analyzers
# WASM_ANALYZERS_PATH=./analyzers
# WASM_ANALYZERS_PATH=/opt/custom-analyzers
# WASM_ANALYZERS_PATH=none  # Disable WASM analyzers

# Config values explicitly passed to WASM analyzers (comma-separated key:value pairs)
# ONLY these values are exposed to untrusted WASM modules
# Example: WASM_ANALYZER_CONFIG=HELIUS_API_KEY:your_key,RPC_URL:https://api.mainnet-beta.solana.com
# WASM_ANALYZER_CONFIG=

# ==============================================================================
# THIRD-PARTY ANALYZER CONFIGURATION
# ==============================================================================
# Enable these for enhanced security analysis with external data sources.
# See ../parapet/src/rules/analyzers/third_party/*.md for details.

# Helius Analyzers (wallet reputation and behavioral analysis)
# - HeliusIdentityAnalyzer: Detects known scammer wallets, 5100+ tagged accounts
# - HeliusTransferAnalyzer: Detects active drains via velocity/pattern analysis (NEW)
# - HeliusFundingAnalyzer: Detects sybil attacks and bot farms (NEW)
# - Requires Helius API key: https://dashboard.helius.dev
# - Docs: ../parapet/src/rules/analyzers/third_party/helius_*.md
# HELIUS_API_KEY=your_helius_api_key_here
#
# New Capabilities (with HELIUS_API_KEY):
# - Active drain detection: >10 tx/hour to same address
# - Compromised AI agent detection: High velocity + concentration
# - Phishing victim detection: 80%+ transfers to same address
# - Sybil wallet detection: Suspicious funding patterns

# Token Mint Analyzer (freeze/mint authority detection)
# - Detects tokens with freeze authority (rug pull risk)
# - Detects unlimited minting capability
# - Uses UPSTREAM_RPC_URL (no additional config needed)
# - Docs: ../parapet/src/rules/analyzers/third_party/token_mint.md
# - Note: Enable with feature flag at compile time

# OtterSec Verified Analyzer (program verification)
# - Cryptographic program verification
# - Detects unverified/tampered programs
# - No API key needed (cryptographic verification)
# - Docs: ../parapet/src/rules/analyzers/third_party/ottersec_verified.md
# - Note: Enable with feature flag at compile time

# Core Analyzers (always enabled, no configuration needed):
# - BasicAnalyzer: Transaction metadata
# - SecurityAnalyzer: Risk scoring, delegation detection
# - TokenInstructionAnalyzer: SPL Token operation analysis
# - SystemProgramAnalyzer: SOL transfers, account operations
# - ProgramComplexityAnalyzer: Program categorization
# Docs: ../parapet/src/rules/analyzers/core/*.md

# ==============================================================================
# AUTOMATIC RULE UPDATES (Multi-Source Community Feeds)
# ==============================================================================
# Auto-sync security rules from multiple sources with caching and rate limiting
# 
# Primary feed source (comma-separated list)
# RULES_FEED_ENABLED=true
# RULES_FEED_URLS=https://parapet-rules.securecheck.io/community/core-protection.json
# RULES_FEED_POLL_INTERVAL=3600  # Check all sources every hour (default: 3600)
#
# For multiple sources, comma-separated:
# RULES_FEED_URLS=https://feeds.securecheck.io/stable,https://feeds.securecheck.io/beta,https://example.com/community.json
#
# Rate limiting (applied to all sources)
# RULES_FEED_MIN_INTERVAL=300  # Minimum seconds between requests per source (default: 300)
#
# Advanced: Override settings per source (optional)
# Format: url:name:priority:min_interval
# RULES_FEED_1=https://feeds.securecheck.io/stable:SecureCheck:0:180
# RULES_FEED_2=https://example.com/community.json:Community:1:600
