# Full Stack Fly.io Configuration

# RPC URLs
UPSTREAM_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Required for API
AUTHORIZED_WALLETS=

# Optional External API Keys
HELIUS_API_KEY=
JUPITER_API_KEY=
OTTERSEC_API_KEY=
MCP_API_KEYS=

# Optional Tuning
DEFAULT_BLOCK_THRESHOLD=70
RUST_LOG=info

# App names
FLY_PROXY_APP=parapet-rpc-proxy
FLY_API_APP=parapet-api
FLY_DASHBOARD_APP=parapet-dashboard
