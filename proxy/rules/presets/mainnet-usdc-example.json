  {
    "version": "1.0",
    "id": "critical-security-all-networks",
    "name": "Critical Security - All Networks",
    "description": "Blocks unlimited delegations on all networks",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "critical", "all-networks"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "delegation_is_unlimited",
        "operator": "equals",
        "value": true
      },
      "message": "🚨 BLOCKED: Unlimited delegation detected - network-agnostic security"
    },
    "metadata": {
      "severity": "critical",
      "weight": 100,
      "networks": "all"
    }
  }
