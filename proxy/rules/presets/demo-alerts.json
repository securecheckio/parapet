[
  {
    "version": "1.0",
    "id": "block-large-sol-transfer",
    "name": "Large SOL Transfer Block",
    "description": "Blocks SOL transfers over 0.5 SOL for testing notifications",
    "author": "securecheck",
    "enabled": true,
    "tags": ["demo", "sol-transfer", "critical", "block"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "system:max_sol_transfer",
        "operator": "greater_than",
        "value": 500000000
      },
      "message": "🚨 BLOCKED: Large SOL transfer (>0.5 SOL) - exceeds safety threshold for testing"
    },
    "metadata": {
      "severity": "critical",
      "threshold_sol": 0.5,
      "weight": 50,
      "networks": ["devnet", "testnet", "mainnet-beta"]
    }
  },
  {
    "version": "1.0",
    "id": "alert-medium-sol-transfer",
    "name": "Medium SOL Transfer Alert",
    "description": "Alerts on SOL transfers over 0.003 SOL for demo purposes",
    "author": "securecheck",
    "enabled": true,
    "tags": ["demo", "sol-transfer", "medium"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "system:max_sol_transfer",
        "operator": "greater_than",
        "value": 3000000
      },
      "message": "⚠️ ALERT: SOL transfer detected (>0.003 SOL) - verify recipient is trusted"
    },
    "metadata": {
      "severity": "medium",
      "threshold_sol": 0.003,
      "weight": 15,
      "networks": ["devnet", "testnet", "mainnet-beta"]
    }
  },
  {
    "version": "1.0",
    "id": "alert-any-sol-transfer",
    "name": "Any SOL Transfer Alert",
    "description": "Alerts on all SOL transfers for maximum visibility",
    "author": "securecheck",
    "enabled": true,
    "tags": ["demo", "sol-transfer", "info"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "system:has_sol_transfer",
        "operator": "equals",
        "value": true
      },
      "message": "ℹ️ NOTICE: SOL transfer detected - monitor for suspicious activity"
    },
    "metadata": {
      "severity": "low",
      "weight": 5,
      "networks": ["devnet", "testnet", "mainnet-beta"]
    }
  },
  {
    "version": "1.0",
    "id": "unlimited-delegation",
    "name": "Unlimited Delegation Alert",
    "description": "Detects unlimited token approvals (u64::MAX) which can indicate drain attacks",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "critical", "delegation"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "delegation_is_unlimited",
        "operator": "equals",
        "value": true
      },
      "message": "🚨 BLOCKED: Unlimited token delegation detected (u64::MAX) - drain attack prevented"
    },
    "metadata": {
      "severity": "critical",
      "false_positive_rate": 0.001,
      "weight": 100,
      "networks": "all"
    }
  },
  {
    "version": "1.0",
    "id": "blocked-programs",
    "name": "Known Malicious Program",
    "description": "Blocks transactions involving known malicious programs",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "critical", "blocklist"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "blocked_program_detected",
        "operator": "equals",
        "value": true
      },
      "message": "🚨 BLOCKED: Known malicious program detected - transaction prevented"
    },
    "metadata": {
      "severity": "critical",
      "false_positive_rate": 0.0,
      "weight": 100,
      "networks": "all"
    }
  },
  {
    "version": "1.0",
    "id": "alert-multiple-transfers",
    "name": "Multiple Transfer Alert",
