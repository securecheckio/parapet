[
  {
    "version": "1.0",
    "id": "block-known-malicious-program-hash",
    "name": "Block Known Malicious Program Hash",
    "description": "Blocks when a transaction includes a program bytecode hash already in blocklist feeds/config.",
    "enabled": true,
    "tags": ["critical", "blocklist", "program-hash"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "program_analysis:is_in_blocklist",
        "operator": "equals",
        "value": true
      },
      "message": "BLOCKED: Known malicious program hash detected."
    },
    "metadata": {
      "confidence": 99,
      "vulnerability": "known_malicious_program"
    }
  },
  {
    "version": "1.0",
    "id": "block-missing-signer-check",
    "name": "Block Missing Signer Check Pattern",
    "description": "Blocks when signer validation appears missing while the program writes state.",
    "enabled": true,
    "tags": ["high", "msc", "signer-check"],
    "rule": {
      "action": "block",
      "conditions": {
        "all": [
          {
            "field": "program_analysis:missing_signer_check",
            "operator": "equals",
            "value": true
          },
          {
            "field": "program_analysis:has_account_write",
            "operator": "equals",
            "value": true
          }
        ]
      },
      "message": "BLOCKED: Program writes account state without signer validation (MSC)."
    },
    "metadata": {
      "confidence": 85,
      "vulnerability": "missing_signer_check"
    }
  },
  {
    "version": "1.0",
    "id": "alert-missing-owner-check",
    "name": "Alert Missing Owner Check Pattern",
    "description": "Alerts when account data reads appear without owner validation.",
    "enabled": true,
    "tags": ["medium", "moc", "owner-check"],
    "rule": {
      "action": "alert",
      "conditions": {
        "field": "program_analysis:missing_owner_check",
        "operator": "equals",
        "value": true
      },
      "message": "WARNING: Program reads account data without owner validation (MOC)."
    },
    "metadata": {
      "confidence": 70,
      "vulnerability": "missing_owner_check"
    }
  },
  {
    "version": "1.0",
    "id": "block-arbitrary-cpi",
    "name": "Block Arbitrary CPI Pattern",
    "description": "Blocks when CPI calls appear without key/owner validation guards.",
    "enabled": true,
    "tags": ["critical", "acpi", "cpi"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "program_analysis:arbitrary_cpi",
        "operator": "equals",
        "value": true
      },
      "message": "BLOCKED: Program appears to perform arbitrary CPI (ACPI)."
    },
    "metadata": {
      "confidence": 90,
      "vulnerability": "arbitrary_cpi"
    }
  }
