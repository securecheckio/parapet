[
  {
    "version": "1.0",
    "id": "block-unlimited-delegation",
    "name": "Block Unlimited Delegations",
    "description": "Blocks unlimited token approvals (u64::MAX)",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "critical", "delegation"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "token_instructions:unlimited_approve_count",
        "operator": "greater_than",
        "value": 0
      },
      "message": "🚨 BLOCKED: Unlimited token delegation detected"
    },
    "metadata": {
      "severity": "critical",
      "weight": 100
    }
  },
  {
    "version": "1.0",
    "id": "block-large-sol-transfer",
    "name": "Block Large SOL Transfer",
    "description": "Blocks transactions transferring >10 SOL",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "critical", "sol-transfer"],
    "rule": {
      "action": "block",
      "conditions": {
        "field": "system:max_sol_transfer",
        "operator": "greater_than",
        "value": 10000000000
      },
      "message": "🚨 BLOCKED: Large SOL transfer detected (>10 SOL)"
    },
    "metadata": {
      "severity": "critical",
      "weight": 80
    }
  },
  {
    "version": "1.0",
    "id": "alert-token-account-for-other",
    "name": "Alert: Creating Token Account for Someone Else",
    "description": "Warns when creating a token account where the owner is not the transaction signer",
    "author": "securecheck",
    "enabled": true,
    "tags": ["security", "high", "wallet-drainer"],
    "rule": {
      "action": "alert",
      "conditions": {
        "all": [
          { "field": "token_instructions:creates_account_for_other", "operator": "equals", "value": true },
          { "field": "token_instructions:transfers_to_newly_created", "operator": "equals", "value": true }
        ]
      },
      "message": "⚠️ WARNING: Creating token account for someone else and transferring tokens"
    },
    "metadata": {
      "severity": "high",
      "weight": 70
    }
  }
]
