# Required: Parapet proxy RPC endpoint
PARAPET_RPC_URL=http://localhost:8899

# Optional: LLM configuration for fallback navigation
# Leave blank to use opportunistic mode only (no LLM)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o

# Optional: Timeout and navigation settings
NAVIGATION_TIMEOUT=30000
MAX_STEPS=10
